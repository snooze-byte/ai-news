# 服务器端口
PORT=3000

# 数据库模式: local=本地SQLite文件, remote=Turso云数据库
# 本地开发用 local, 部署到 Railway/Render 用 remote
DB_MODE=remote

# Turso 数据库配置 (https://turso.tech)
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# AI API 配置 (兼容 OpenAI / DeepSeek)
OPENAI_API_KEY=sk-your-api-key
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# 每日简报定时任务 (默认每天早上8:00 UTC+8)
CRON_SCHEDULE=0 8 * * *

# RSS 抓取条数
NEWS_FETCH_COUNT=10
